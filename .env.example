# ============================================
# Crucix Intelligence Engine — Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Keys are optional — sources without keys degrade gracefully.
#
# IMPORTANT: Do NOT put comments on the same line as values.
# Docker env_file treats inline comments as part of the value.

# === OSINT Source API Keys ===

# Federal Reserve Economic Data (free: fred.stlouisfed.org/docs/api)
FRED_API_KEY=
# NASA FIRMS fire data (free: firms.modaps.eosdis.nasa.gov/api)
FIRMS_MAP_KEY=
# Energy Information Administration (free: api.eia.gov/register)
EIA_API_KEY=
# Maritime AIS data (aisstream.io)
AISSTREAM_API_KEY=
# Armed Conflict Location & Event Data (acleddata.com/user/register)
# Register with an institutional email (not Gmail) for Research-tier API access.
# Crucix calls GET /api/acled/read (event data) — NOT ACLED Partner "briefings."
# Research tier: latent event data with ~12-month lag (https://acleddata.com/faq-codebook-tools)
ACLED_EVENT_LAG_DAYS=365
ACLED_EVENT_WINDOW_DAYS=7
# Partner/Enterprise near-real-time: ACLED_EVENT_LAG_DAYS=7 (or 0)
#
# Recommended: email/password only. Crucix fetches OAuth tokens automatically and
# saves access + refresh tokens to runs/.cache/acled-oauth.json (refreshes ~24h).
ACLED_EMAIL=
ACLED_PASSWORD=
# Optional legacy bootstrap (only if email/password not set):
# ACLED_ACCESS_TOKEN=
# ACLED_REFRESH_TOKEN=
# Use curl for ACLED HTTP (default when curl is installed — required in Docker/NUC behind Cloudflare)
ACLED_USE_CURL=1
# Chrome TLS impersonation when curl/fetch are blocked (installed via optional npm dep; enabled in Docker)
ACLED_USE_CYCLETLS=1
# Cloudflare Radar internet outages & traffic anomalies (free: dash.cloudflare.com/profile/api-tokens, Account Analytics Read)
CLOUDFLARE_API_TOKEN=

# === Server Configuration ===

# Docker file ownership — set to your host user so runs/ is writable from host scripts.
# On Linux NUC: id -u && id -g  (typically 1000:1000)
PUID=1000
PGID=1000

# Dashboard server port
PORT=3117
# Auto-refresh interval (minutes)
REFRESH_INTERVAL_MINUTES=15

# === LLM Layer (optional) ===
# Enables AI-enhanced trade ideas and breaking news Telegram alerts.
# Provider options: anthropic | openai | gemini | codex | openrouter | minimax | mistral | ollama | grok
LLM_PROVIDER=
# Not needed for codex (uses ~/.codex/auth.json) or ollama (local)
LLM_API_KEY=
# Optional override. Each provider has a sensible default:
# anthropic: claude-sonnet-4-6 | openai: gpt-5.4 | gemini: gemini-3.1-pro | codex: gpt-5.3-codex | openrouter: openrouter/auto | minimax: MiniMax-M2.5 | ollama: llama3.1:8b | grok: grok-4-latest
LLM_MODEL=
# Ollama base URL (only needed if not using default http://localhost:11434)
OLLAMA_BASE_URL=

# === Telegram Alerts (optional — LLM enhances tier decisions but is not required) ===
# Create a bot via @BotFather, get chat ID via @userinfobot
# Full setup guide: TELEGRAM_ALERTS.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: scheduled daily summary at a fixed local time (24h HH:MM).
# Leave blank to disable. Independent of the reactive alert system.
TELEGRAM_DAILY_BRIEF_TIME=
# Optional: IANA timezone for the daily brief (e.g. America/New_York).
# Defaults to the server's system timezone.
TELEGRAM_DAILY_BRIEF_TZ=
# Optional: set to "true" if /mute should also silence the daily brief.
# Default behavior: daily brief is a digest, not an alert, so /mute does NOT silence it.
TELEGRAM_DAILY_BRIEF_RESPECT_MUTE=

# === Dashboard admin (optional) ===
# When set, POST/PUT/DELETE on /api/config/sources require:
#   Authorization: Bearer <ADMIN_TOKEN>
# Generate locally: openssl rand -hex 32   (or any long random string)
ADMIN_TOKEN=

# ReliefWeb humanitarian API appname (register at https://apidoc.reliefweb.int/parameters#appname)
RELIEFWEB_APPNAME=

# User-managed RSS feeds file (default: runs/config/custom-sources.json)
# CUSTOM_SOURCES_USER_FILE=runs/config/custom-sources.json
# Append-only history per custom source (JSONL under runs/memory/custom/). Set to 0 to disable.
# CUSTOM_SOURCES_HISTORY=1
# CUSTOM_SOURCES_HISTORY_DIR=runs/memory/custom
# CUSTOM_SOURCES_HISTORY_MAX=500

# === Custom OSINT Sources (optional) ===
# Seed sources live in crucix.config.mjs. Add more via the dashboard Sources modal
# or by editing the user file above. Firecrawl variables below only matter for type:'firecrawl'.
#
# Firecrawl API key (https://firecrawl.dev — free tier is ~500 credits/mo).
FIRECRAWL_API_KEY=
# Optional self-hosted Firecrawl URL (defaults to https://api.firecrawl.dev).
FIRECRAWL_BASE_URL=
# Hard cap on Firecrawl scrapes per sweep (protects the free tier).
FIRECRAWL_MAX_PER_SWEEP=5

# === Geocoding (optional, for custom-source globe markers) ===
# Enable "Geocoding API" in Google Cloud Console (separate from the Maps
# JavaScript embed key). When unset, the system falls back to free
# OpenStreetMap Nominatim (rate-limited to ~1 req/sec).
# Results are disk-cached at runs/.cache/geocode/ for 30 days.
GOOGLE_GEOCODING_API_KEY=
